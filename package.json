{
    "name": "nestelligence",
    "version": "0.2.0",
    "description": "Provider-agnostic NestJS AI library with decorator-first DX.",
    "license": "MIT",
    "type": "commonjs",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md"
    ],
    "engines": {
        "node": ">=18.18.0"
    },
    "scripts": {
        "prepublishOnly": "npm run build",
        "build": "tsc -p tsconfig.build.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "npm run test:all",
        "test:all": "jest --config jest.config.ts",
        "test:unit": "jest --config jest.unit.config.ts",
        "test:integration": "jest --config jest.integration.config.ts",
        "test:e2e": "jest --config jest.e2e.config.ts",
        "test:coverage": "jest --config jest.config.ts --coverage"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/core": "^11.0.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "zod": "^3.25.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@nestjs/testing": "^11.0.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.17.0",
        "@types/supertest": "^6.0.3",
        "jest": "^29.7.0",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.3"
    }
}